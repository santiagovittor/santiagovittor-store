# GA4 Measurement ID (public, read client-side). Get from analytics.google.com.
# Leave empty to disable GA4 (local dev). Vercel Web Analytics needs no key.
NEXT_PUBLIC_GA_ID=

# NVIDIA NIM API key (chat primary model, free tier). Get from build.nvidia.com.
NVIDIA_API_KEY=

# Google Generative AI key (chat fallback model, free tier). Get from aistudio.google.com.
GOOGLE_GENERATIVE_AI_API_KEY=

# Resend API key (chat submit_contact email tool). Get from resend.com.
RESEND_API_KEY=
